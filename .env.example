# Copy this file to .env and fill in the values for your machine.
# On the server, keep a separate .env with that machine's specs.

# ── LLM server ────────────────────────────────────────────────────────────────
LLAMA_MODEL=Qwen2.5-Coder-7B-Instruct-AWQ
LLAMA_BASE_URL=http://localhost:8080/v1

# ── Agent behaviour ───────────────────────────────────────────────────────────
MAX_REACT_STEPS=8

# ── Hardware metadata (written into run_info; does not affect execution) ───────
HW_GPU=NVIDIA RTX 4090
HW_GPU_COUNT=1
HW_VRAM_TOTAL_MB=24564
HW_CPU=AMD Ryzen 9 7950X
HW_CPU_CORES=16
HW_RAM_TOTAL_MB=65536

# ── vLLM / llama-server launch settings ──────────────────────────────────────
VLLM_GPU_MEM_UTIL=0.9
VLLM_MAX_MODEL_LEN=8192
VLLM_DTYPE=float16
VLLM_QUANTIZATION=awq
