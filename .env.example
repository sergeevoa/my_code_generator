# ── LLM server ────────────────────────────────────────────────────────────────
LLAMA_MODEL=Qwen3-14B-Q4_K_M-GGUF.gguf
LLAMA_BASE_URL=http://localhost:8080/v1

# ── Agent behaviour ───────────────────────────────────────────────────────────
MAX_REACT_STEPS=8
# Max tokens generated per step. Must be < n_ctx_slot on the server.
# n_ctx_slot = -c / --parallel  (e.g. -c 32768 --parallel 4 → slot=8192).
MAX_TOKENS=16384

# Soft limit on <think> tokens per step (Qwen3 chat_template_kwargs).
# Must be < MAX_TOKENS. Reduce to cut tail latency and timeouts.
QB_THINKING_BUDGET=5120

# ── Hardware (local machine) ─────────────────────────────────────────────────────────────────────────────────────────
HW_GPU=NVIDIA RTX 3090
HW_GPU_COUNT=1
HW_VRAM_TOTAL_MB=24576

HW_CPU=Unknown (18 vCPU @ 2.4-4 GHz)
HW_CPU_CORES=18

HW_RAM_TOTAL_MB=32768

# ── vLLM / llama-server settings ─────────────────────────────────────────────
VLLM_GPU_MEM_UTIL=1
VLLM_MAX_MODEL_LEN=16384
VLLM_DTYPE=float16
VLLM_QUANTIZATION=Q4_K_M